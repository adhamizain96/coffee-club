generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TagType {
  AMENITY
  VIBE
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

model Cafe {
  id            String    @id @default(cuid())
  name          String
  description   String
  address       String
  neighborhood  String
  latitude      Float
  longitude     Float
  imageUrl      String    @map("image_url")
  ownerReview   String    @map("owner_review")
  createdAt     DateTime  @default(now()) @map("created_at")
  submitterName String?   @map("submitter_name")
  addedAt       DateTime? @map("added_at")

  tags        CafeTag[]
  notes       Note[]
  submissions CafeSubmission[]

  @@map("cafes")
}

model Tag {
  id   String  @id @default(cuid())
  name String  @unique
  type TagType

  cafes CafeTag[]

  @@map("tags")
}

model CafeTag {
  id     String @id @default(cuid())
  cafeId String @map("cafe_id")
  tagId  String @map("tag_id")

  cafe Cafe @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([cafeId, tagId])
  @@map("cafe_tags")
}

model Note {
  id         String   @id @default(cuid())
  cafeId     String   @map("cafe_id")
  content    String   @db.VarChar(500)
  authorName String?  @map("author_name")
  createdAt  DateTime @default(now()) @map("created_at")

  cafe Cafe @relation(fields: [cafeId], references: [id], onDelete: Cascade)

  @@map("notes")
}

model CafeSubmission {
  id                String           @id @default(cuid())
  cafeName          String           @map("cafe_name")
  address           String
  normalizedAddress String           @map("normalized_address")
  website           String
  whyYouLikeIt      String?          @map("why_you_like_it") @db.VarChar(280)
  suggestedTagIds   String[]         @map("suggested_tag_ids")
  submitterName     String           @map("submitter_name")
  status            SubmissionStatus @default(PENDING)
  createdAt         DateTime         @default(now()) @map("created_at")
  reviewedAt        DateTime?        @map("reviewed_at")
  rejectionReason   String?          @map("rejection_reason")
  approvedCafeId    String?          @map("approved_cafe_id")

  approvedCafe Cafe? @relation(fields: [approvedCafeId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([normalizedAddress])
  @@map("cafe_submissions")
}
