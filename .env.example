# Copy to .env and fill in. See README's "Set up environment variables" for details.

# ---------------------------------------------------------------------------
# Database — local dev
# ---------------------------------------------------------------------------
# Both URLs come from `npx prisma dev` output. Run that first; the command
# prints exactly these two strings.

# Raw postgres:// URL — used by the app (PrismaPg adapter) and the seed script.
DATABASE_URL="postgres://postgres:postgres@localhost:51214/template1?sslmode=disable&connection_limit=10&connect_timeout=0&max_idle_connection_lifetime=0&pool_timeout=0&socket_timeout=0"

# prisma+postgres:// proxy URL — used by prisma.config.ts for `db push` and migrations.
PRISMA_PROXY_URL="prisma+postgres://localhost:51213/?api_key=REPLACE_WITH_KEY_FROM_PRISMA_DEV_OUTPUT"

# Optional: override DATABASE_URL just for the seed script when the main
# DATABASE_URL points at a non-direct connection (e.g. a hosted pooler).
# Falls back to DATABASE_URL when unset. Leave commented out for local dev.
# SEED_DATABASE_URL="postgres://..."

# ---------------------------------------------------------------------------
# Google Maps
# ---------------------------------------------------------------------------
# Used by:
#   - the map view in the app (Maps JavaScript API)
#   - scripts/geocode-cafes.ts (Geocoding API)
# Get a key at https://console.cloud.google.com/google/maps-apis/credentials
# The geocode script needs an unrestricted or IP-restricted key — referrer-only
# browser keys will fail server-side with REQUEST_DENIED.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
